# Google Gemini API key — get a free one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here
# Primary model (free tier). gemini-flash-latest is capable and has free quota.
MODEL_NAME=gemini-flash-latest
# Optional comma-separated fallback models tried if the primary is rate-limited /
# its small daily free-tier quota is used up. gemini-2.0-flash is 0-quota on some keys.
FALLBACK_MODELS=gemini-2.5-flash
